# ============================================================================
# Application Settings
# ============================================================================
APP_NAME=Avatar AI Backend
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_JSON=False

# ============================================================================
# Server Configuration
# ============================================================================
HOST=0.0.0.0
PORT=8000

# ============================================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================================
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:4173", "http://localhost:3001"]
PRODUCTION_ALLOWED_ORIGINS=[]

# ============================================================================
# Groq API Configuration (ASR + LLM)
# ============================================================================
# REQUIRED: Get your key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ============================================================================
# ASR (Automatic Speech Recognition) Settings
# ============================================================================
ASR_MODEL=whisper-large-v3
ASR_LANGUAGE=en
ASR_RESPONSE_FORMAT=verbose_json

# ============================================================================
# Audio Buffer Configuration
# ============================================================================
MAX_AUDIO_BUFFER_SIZE=10485760   # 10MB
AUDIO_CHUNK_TIMEOUT=30

# ============================================================================
# LLM (Large Language Model) Settings (for chat, not RAG)
# ============================================================================
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7
LLM_SYSTEM_PROMPT=You are a smart and friendly educational assistant. You explain concepts in a simple and clear manner. Your answers are concise and helpful.

# ============================================================================
# TTS (Text-to-Speech) Settings
# ============================================================================
TTS_VOICE=en-US-AriaNeural
TTS_RATE=+0%
TTS_VOLUME=+0%
TTS_PITCH=+0Hz
TTS_VISEME_DEFAULT_DURATION_MS=60.0
TTS_TIMEOUT_SEC=60.0

# ============================================================================
# Avatar Configuration
# ============================================================================
DEFAULT_AVATAR_ID=avatar1
VALID_AVATAR_IDS=["avatar1", "avatar2", "avatar3"]

# ============================================================================
# WebSocket Configuration
# ============================================================================
WS_HEARTBEAT_INTERVAL=30
WS_HEARTBEAT_TIMEOUT=90
WS_MAX_MESSAGE_SIZE=10485760   # 10MB

# ============================================================================
# Session Management
# ============================================================================
SESSION_TIMEOUT_SEC=300         # 5 minutes
SESSION_CLEANUP_INTERVAL=60     # seconds

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MESSAGES_PER_MINUTE=60
RATE_LIMIT_CONNECTIONS_PER_IP=60
TRUST_PROXY_HEADERS=False

# ============================================================================
# Storage Configuration
# ============================================================================
AUDIO_STORAGE_PATH=.data/sessions
AUDIO_FILE_TTL_HOURS=24

# ============================================================================
# Audio Processing
# ============================================================================
AUDIO_MAX_DURATION_SEC=30
AUDIO_SAMPLE_RATE=16000

# ============================================================================
# PostgreSQL + pgvector Configuration
# ============================================================================
POSTGRES_USER=Your_Postgres_Username
POSTGRES_PASSWORD=Your_Postgres_Password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=virtai
# DATABASE_URL is constructed automatically from the above variables

# ============================================================================
# Redis Configuration
# ============================================================================
# Format: redis://[:password@]host:port/db
REDIS_URL=redis://localhost:6379/0

# Redis TTLs (seconds)
REDIS_CHAT_CONTEXT_TTL=3600      # 1 hour — active chat context
REDIS_TTS_CACHE_TTL=86400        # 24 hours — synthesised audio
REDIS_LLM_CACHE_TTL=1800         # 30 minutes — LLM completions
REDIS_JWT_BLACKLIST_TTL=604800   # 7 days — matches refresh token lifetime
REDIS_AUTH_SESSION_TTL=900       # 15 minutes — user profile cache for auth checks
REDIS_TOKEN_VALIDATION_TTL=120   # 2 minutes — short-lived JTI validity cache

# ============================================================================
# JWT Authentication
# ============================================================================
# IMPORTANT: Change this to a long random string in production!
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# Google OAuth Authentication (optional)
# ============================================================================
# Go to https://console.cloud.google.com/ > APIs & Services > OAuth consent screen
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ============================================================================
# RAG (Retrieval-Augmented Generation) Configuration
# ============================================================================

# --- Vector Database Backend ---
# Options: PGVECTOR (recommended for startup) or QDRANT
VECTOR_DB_BACKEND=PGVECTOR
VECTOR_DB_DISTANCE_METHOD=cosine   # cosine or dot

# --- Embedding Provider ---
# Options: fastembed, openai, cohere
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
FASTEMBED_CACHE_DIR=/app/.cache/fastembed
FASTEMBED_LAZY_LOAD=false

# --- Generation Provider (for RAG answers) ---
# Options: openai, cohere
GENERATION_PROVIDER=openai
GENERATION_MODEL=gpt-3.5-turbo
GENERATION_MAX_TOKENS=1000
GENERATION_TEMPERATURE=0.3

# --- Reranker Provider (optional) ---
RERANKER_PROVIDER=cohere
RERANKER_MODEL=rerank-english-v3.0

# --- API Keys for RAG providers ---
OPENAI_API_KEY=your_openai_api_key_here
COHERE_API_KEY=your_cohere_api_key_here

# --- Document Processing ---
CHUNK_SIZE=1000            # characters per chunk
CHUNK_OVERLAP=200          # overlap between chunks
MAX_UPLOAD_SIZE_MB=25      # maximum file upload size in MB
ALLOWED_FILE_TYPES=["pdf","txt","md"]

# --- Localization (for templates) ---
PRIMARY_LANG=en
DEFAULT_LANG=en

# ============================================================================
# Optional: Napkin AI for diagram generation (if you use it)
# ============================================================================
NAPKIN_API_KEY=
