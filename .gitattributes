# Normalize line endings to LF for all text files
* text=auto eol=lf

# Explicitly declare common text files
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.env*      text eol=lf

# Binary files — no conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.webp      binary
*.ico       binary
*.woff      binary
*.woff2     binary
