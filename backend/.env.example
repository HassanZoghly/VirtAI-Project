# ============================================================================
# Application Settings
# ============================================================================
APP_NAME=Avatar AI Backend
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# ============================================================================
# Server Configuration
# ============================================================================
HOST=0.0.0.0
PORT=8000

# ============================================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================================
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:4173", "http://localhost:3001"]

# ============================================================================
# Groq API Configuration
# ============================================================================
# REQUIRED: Get your key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ============================================================================
# ASR (Automatic Speech Recognition) Settings
# ============================================================================
ASR_MODEL=whisper-large-v3
ASR_LANGUAGE=en
ASR_RESPONSE_FORMAT=verbose_json

# ============================================================================
# Audio Buffer Configuration
# ============================================================================
MAX_AUDIO_BUFFER_SIZE=10485760
AUDIO_CHUNK_TIMEOUT=30

# ============================================================================
# LLM (Large Language Model) Settings
# ============================================================================
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7
LLM_SYSTEM_PROMPT=You are a smart and friendly educational assistant. You explain concepts in a simple and clear manner. Your answers are concise and helpful.

# ============================================================================
# TTS (Text-to-Speech) Settings
# ============================================================================
TTS_VOICE=en-US-AriaNeural
TTS_RATE=+0%
TTS_VOLUME=+0%
TTS_PITCH=+0Hz
TTS_VISEME_DEFAULT_DURATION_MS=60.0

# ============================================================================
# Avatar Configuration
# ============================================================================
DEFAULT_AVATAR_ID=avatar1
VALID_AVATAR_IDS=["avatar1", "avatar2", "avatar3"]

# ============================================================================
# WebSocket Configuration
# ============================================================================
WS_HEARTBEAT_INTERVAL=30
WS_HEARTBEAT_TIMEOUT=90
WS_MAX_MESSAGE_SIZE=10485760

# ============================================================================
# Session Management
# ============================================================================
SESSION_TIMEOUT_SEC=300
SESSION_CLEANUP_INTERVAL=60

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MESSAGES_PER_MINUTE=60
RATE_LIMIT_CONNECTIONS_PER_IP=5

# ============================================================================
# Storage Configuration
# ============================================================================
AUDIO_STORAGE_PATH=backend/.data/sessions
AUDIO_FILE_TTL_HOURS=24

# ============================================================================
# Audio Processing
# ============================================================================
AUDIO_MAX_DURATION_SEC=30
AUDIO_SAMPLE_RATE=16000

# ============================================================================
# MongoDB Configuration
# ============================================================================
MONGODB_URL=mongodb://username:password@host:27017/dbname
MONGODB_DB_NAME=virtai

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# Redis TTLs (seconds)
REDIS_CHAT_CONTEXT_TTL=3600      # 1 hour — active chat context
REDIS_TTS_CACHE_TTL=86400        # 24 hours — synthesised audio
REDIS_LLM_CACHE_TTL=1800         # 30 minutes — LLM completions
REDIS_JWT_BLACKLIST_TTL=604800   # 7 days — matches refresh token lifetime

# ============================================================================
# JWT Authentication
# ============================================================================
# IMPORTANT: Change this to a long random string in production!
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# Google OAuth Authentication
# ============================================================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
