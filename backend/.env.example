# =============================================================================
# VirtAI Backend — .env.example
# =============================================================================
# Copy to .env and fill in real values. Anything left blank uses Settings defaults.
# After editing, restart BOTH the API (uvicorn) AND the worker (arq).
# =============================================================================

# ---------- App ----------
APP_NAME="VirtAI Backend"
APP_VERSION="1.0.0"
ENVIRONMENT=development        # development | testing | production
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=false                 # true in production
HOST=0.0.0.0
PORT=8000

# ---------- CORS ----------
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:4173", "http://localhost:3001"]
PRODUCTION_ALLOWED_ORIGINS=[]

# ---------- Database ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=virtai

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- JWT / Auth ----------
# REQUIRED in production — generate via: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ISSUER=virtai-api
JWT_AUDIENCE=virtai-client
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- Google OAuth (optional) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# =============================================================================
# AI Providers — RAG STACK
# =============================================================================

# ---------- Embedding (REQUIRED) ----------
# Mini-RAG used Cohere multilingual. Recommended for Arabic + English content.
EMBEDDING_PROVIDER=cohere                      # cohere | openai | fastembed
EMBEDDING_MODEL=embed-multilingual-v3.0        # 1024d, supports 100+ langs
EMBEDDING_DIMENSION=1024                       # MUST match the model's native dim
# Legacy aliases (also accepted for backward compat with Mini-RAG .env):
# EMBEDDING_BACKEND=cohere
# EMBEDDING_MODEL_ID=embed-multilingual-v3.0
# EMBEDDING_MODEL_SIZE=1024

# Alternative if no Cohere key:
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_DIMENSION=1024                     # reduced from native 3072 via API param

# Free/local alternative (English-only, lower quality for Arabic):
# EMBEDDING_PROVIDER=fastembed
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# EMBEDDING_DIMENSION=384

# ---------- Generation / LLM (REQUIRED) ----------
GENERATION_PROVIDER=groq                       # groq | openai | cohere
GENERATION_MODEL=llama-3.3-70b-versatile
GENERATION_MAX_TOKENS=1500
GENERATION_TEMPERATURE=0.2

# Legacy chat-only LLM (used by non-RAG paths):
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7

# ---------- Reranker ----------
RERANKER_PROVIDER=cohere                       # cohere | cross-encoder
RERANKER_MODEL=rerank-multilingual-v3.0        # supports Arabic
# Fallback if Cohere unavailable:
# RERANKER_PROVIDER=cross-encoder
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ---------- Vision (NEW — for diagrams & scanned PDFs) ----------
VISION_PROVIDER=openai                         # openai | disabled
VISION_MODEL=gpt-4o-mini                       # cheap + good quality
VISION_MAX_IMAGES_PER_DOC=30                   # cost guard

# ---------- Vector Store ----------
VECTOR_DB_BACKEND=PGVECTOR                     # PGVECTOR | QDRANT
VECTOR_DB_DISTANCE_METHOD=cosine
RAG_MIN_HYBRID_SCORE=0.015
RAG_MIN_DENSE_SCORE=0.5

# ---------- API Keys ----------
GROQ_API_KEY=                                  # https://console.groq.com/keys
OPENAI_API_KEY=                                # https://platform.openai.com/api-keys
COHERE_API_KEY=                                # https://dashboard.cohere.com/api-keys
HF_TOKEN=                                      # https://huggingface.co/settings/tokens
NAPKIN_API_KEY=                                # https://napkin.ai (optional, for visualizations)

# =============================================================================
# Chunking / Ingestion
# =============================================================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_BATCH_SIZE=32
MAX_CHUNKS_PER_DOCUMENT=2000
MAX_UPLOAD_SIZE_MB=25
# After BATCH 9, supported types:
ALLOWED_FILE_TYPES=["pdf","txt","md","png","jpg","jpeg","webp"]
STALE_QUEUE_THRESHOLD_MINUTES=15
MAX_ACTIVE_JOBS_PER_USER=3
ARQ_MAX_TRIES=3

# =============================================================================
# Languages
# =============================================================================
PRIMARY_LANG=en        # en | ar — affects prompt templates
DEFAULT_LANG=en

# =============================================================================
# Debug / Quality (optional)
# =============================================================================
RAG_DEBUG=false        # Set to true to log retrieved chunks + scores per query

# =============================================================================
# ASR / TTS / Avatar (unrelated to RAG, defaults below)
# =============================================================================
ASR_MODEL=whisper-large-v3
ASR_LANGUAGE=en
TTS_VOICE=en-US-AriaNeural
ENABLE_FILLER_AUDIO=false
DEFAULT_AVATAR_ID=avatar1

# =============================================================================
# Trust proxy headers (set true if behind nginx/ALB/CloudFront)
# =============================================================================
TRUST_PROXY_HEADERS=false

# =============================================================================
# Cookie domain (set to your apex in production, e.g. ".virtai.app")
# =============================================================================
COOKIE_DOMAIN=

# =============================================================================
# Animation assets path (resolve relative to backend/app/)
# =============================================================================
# ANIMATION_ASSETS_DIR=
