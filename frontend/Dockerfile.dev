FROM node:22-bookworm-slim

WORKDIR /app

COPY package*.json ./
RUN HUSKY=0 npm install --no-audit --no-fund --legacy-peer-deps

COPY public ./public
COPY src ./src
COPY index.html ./
COPY vite.config.* ./
COPY tsconfig*.json ./

EXPOSE 3000

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
