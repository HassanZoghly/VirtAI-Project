{
    "name": "virtai-react",
    "description": "VirtAI - Virtual AI Assistant for Speech & Chat (React)",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "test": "vitest --run",
        "test:watch": "vitest",
        "lint": "eslint src --ext .js,.jsx",
        "lint:fix": "eslint src --ext .js,.jsx --fix",
        "format": "prettier --write \"src/**/*.{js,jsx,json,css}\"",
        "format:check": "prettier --check \"src/**/*.{js,jsx,json,css}\""
    },
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@react-three/drei": "^9.105.6",
        "@react-three/fiber": "^8.16.8",
        "axios": "^1.13.6",
        "clsx": "^2.1.1",
        "lottie-react": "^2.4.1",
        "motion": "^12.35.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-helmet-async": "^2.0.5",
        "react-hook-form": "^7.71.2",
        "react-icons": "^5.3.0",
        "react-router-dom": "^6.26.2",
        "tailwind-merge": "^3.5.0",
        "three": "0.160.0",
        "zod": "^4.3.6",
        "zustand": "^5.0.11"
    },
    "overrides": {
        "three": "0.160.0",
