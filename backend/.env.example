# ============================================================================
# AI Avatar Chat Backend - Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual values
# All settings have sensible defaults for development

# ============================================================================
# Application Settings
# ============================================================================

# Application name and version (informational)
APP_NAME=Avatar AI Backend
APP_VERSION=1.0.0

# Enable debug mode for detailed error messages and logging
# Set to False in production for security
DEBUG=True

# Environment mode: development or production
# Affects CORS behavior and logging verbosity
ENVIRONMENT=development

# ============================================================================
# Server Configuration
# ============================================================================

# Server host and port
# Use 0.0.0.0 to accept connections from any network interface
HOST=0.0.0.0
PORT=8000

# ============================================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================================

# Allowed origins for CORS requests
# Can be a JSON array or comma-separated list
# Add your frontend URLs here (React dev server, production domain, etc.)
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:4173"]

# ============================================================================
# Groq API Configuration
# ============================================================================

# REQUIRED: Your Groq API key for LLM and ASR services
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ============================================================================
# ASR (Automatic Speech Recognition) Settings
# ============================================================================

# Whisper model for speech-to-text via Groq
# Options: whisper-large-v3, whisper-large-v3-turbo
ASR_MODEL=whisper-large-v3-turbo

# Language code for ASR (ISO 639-1 format)
# Examples: en, es, fr, de, ja, zh
ASR_LANGUAGE=en

# Response format for ASR results
# verbose_json provides timestamps and word-level details
ASR_RESPONSE_FORMAT=verbose_json

# ============================================================================
# Audio Buffer Configuration
# ============================================================================

# Maximum audio buffer size (bytes)
# 10 MB = 10485760 bytes
MAX_AUDIO_BUFFER_SIZE=10485760

# Audio chunk timeout (seconds)
# Buffer is cleared if no final chunk received within this time
AUDIO_CHUNK_TIMEOUT=30

# ============================================================================
# LLM (Large Language Model) Settings
# ============================================================================

# Groq LLM model for chat responses
# Options: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
LLM_MODEL=llama-3.3-70b-versatile

# Maximum tokens to generate in LLM response
# Lower values = faster responses, higher values = more detailed answers
LLM_MAX_TOKENS=512

# Temperature for LLM generation (0.0 to 2.0)
# Lower = more focused/deterministic, higher = more creative/random
LLM_TEMPERATURE=0.7

# System prompt that defines the AI assistant's personality and behavior
# Customize this to change how the avatar responds
LLM_SYSTEM_PROMPT=You are a smart and friendly educational assistant. You explain concepts in a simple and clear manner. Your answers are concise and helpful.

# ============================================================================
# TTS (Text-to-Speech) Settings
# ============================================================================

# Edge TTS voice for audio generation
# Popular options: en-US-AriaNeural, en-US-GuyNeural, en-GB-SoniaNeural
# Full list: https://speech.microsoft.com/portal/voicegallery
TTS_VOICE=en-US-AriaNeural

# Speech rate adjustment (-50% to +100%)
# Examples: -20% (slower), +0% (normal), +50% (faster)
TTS_RATE=+0%

# Volume adjustment (-50% to +100%)
# Examples: -20% (quieter), +0% (normal), +50% (louder)
TTS_VOLUME=+0%

# Pitch adjustment (-50Hz to +50Hz)
# Examples: -10Hz (lower), +0Hz (normal), +10Hz (higher)
TTS_PITCH=+0Hz

# ============================================================================
# WebSocket Configuration
# ============================================================================

# Interval between heartbeat ping messages (seconds)
# Client must respond with pong within timeout period
WS_HEARTBEAT_INTERVAL=30

# Maximum time to wait for heartbeat pong response (seconds)
# Connection is closed if no pong received within this time
WS_HEARTBEAT_TIMEOUT=90

# Maximum size of WebSocket messages (bytes)
# 10 MB = 10485760 bytes
WS_MAX_MESSAGE_SIZE=10485760

# ============================================================================
# Session Management
# ============================================================================

# Session timeout for idle conversations (seconds)
# Sessions inactive for this duration are cleaned up
# 300 seconds = 5 minutes
SESSION_TIMEOUT_SEC=300

# Interval for running session cleanup task (seconds)
# Background task checks for idle sessions at this frequency
SESSION_CLEANUP_INTERVAL=60

# ============================================================================
# Rate Limiting
# ============================================================================

# Maximum requests per window period
RATE_LIMIT_REQUESTS=60

# Time window for rate limiting (seconds)
RATE_LIMIT_WINDOW=60

# Maximum chat messages per minute per session
RATE_LIMIT_MESSAGES_PER_MINUTE=60

# Maximum concurrent WebSocket connections per IP address
RATE_LIMIT_CONNECTIONS_PER_IP=5

# ============================================================================
# Storage Configuration
# ============================================================================

# Directory path for storing generated audio files
# Audio files are organized by session_id/message_id.mp3
AUDIO_STORAGE_PATH=backend/.data/sessions

# Time-to-live for audio files (hours)
# Files older than this are eligible for cleanup
AUDIO_FILE_TTL_HOURS=24

# ============================================================================
# Audio Processing
# ============================================================================

# Maximum duration for audio recordings (seconds)
# Prevents excessively long audio processing
AUDIO_MAX_DURATION_SEC=30

# Sample rate for audio processing (Hz)
# 16000 Hz is standard for speech recognition
AUDIO_SAMPLE_RATE=16000
