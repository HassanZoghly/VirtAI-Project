        "@testing-library/react": "^16.3.2",
        "@vitejs/plugin-react": "^4.2.1",
        "eslint": "^8.57.0",
        "eslint-plugin-react": "^7.33.2",
        "eslint-plugin-react-hooks": "^4.6.0",
        "fast-check": "^4.5.3",
        "happy-dom": "^20.7.0",
        "prettier": "^3.2.5",
        "tailwindcss": "^4.2.1",
        "vite": "^7.3.1",
        "vitest": "^4.0.18"
    },
    "engines": {
        "node": ">=18.18"
    }
