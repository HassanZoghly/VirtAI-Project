# App
DEBUG=True
ENVIRONMENT=development

# Groq
GROQ_API_KEY=your_groq_api_key_here

# ASR
ASR_LANGUAGE=en

# LLM
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7

# TTS
TTS_VOICE=en-US-AriaNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz

# CORS
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:4173", "http://localhost:3001"]